---
import Countdown from "~/components/Countdown";
import ThemeToggle from "~/components/ThemeToggle";
import '~/styles/global.css';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TimeSplit</title>
    <script is:inline>
      (function(){
        try {
          const t = localStorage.getItem('theme');
          if (t === 'dark' || (t == null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
	</head>
	<body class="bg-white text-slate-900 dark:bg-slate-900 dark:text-slate-100 antialiased">
		<main class="min-h-svh grid place-items-center p-6">
			<div class="w-full max-w-4xl flex flex-col items-center justify-center">
				<div class="flex items-center justify-between w-[92%] mb-4">
					<h1 class="m-0 text-2xl sm:text-3xl font-extrabold">TimeSplit</h1>
					<ThemeToggle client:load />
				</div>
				<Countdown client:load />
			</div>
		</main>
	</body>
</html>


