---
import Countdown from "~/components/Countdown";
import { COUNTDOWN_TARGET_ISO } from "~/config/countdown";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>TimeSplit - Contador</title>
		<style>
			:root { color-scheme: light dark; }
			body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Helvetica, Arial, sans-serif; }
			.container { min-height: 100svh; display: grid; place-items: center; background: var(--bg, #f8fafc); }
			.card { max-width: 960px; width: 100%; padding: 2rem; }
			.h1 { font-size: clamp(1.75rem, 1.2rem + 2vw, 2.5rem); font-weight: 800; margin: 0 0 1rem 0; }
			.p { color: #6b7280; margin: 0 0 2rem 0; }
		</style>
	</head>
	<body>
		<main class="container">
			<section class="card">
				<h1 class="h1">Contador hasta {COUNTDOWN_TARGET_ISO}</h1>
				<p class="p">Modifica la fecha global en <code>src/config/countdown.ts</code> para cambiar el objetivo.</p>
				<Countdown client:load />
			</section>
		</main>
	</body>
</html>


